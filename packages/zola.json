{
  "name": "zola",
  "repo": "getzola/zola",
  "description": "A fast static site generator in a single binary with everything built-in",
  "binary": "zola",
  "license": "MIT",
  "homepage": "https://github.com/getzola/zola",
  "asset_pattern": {
    "linux_amd64": "zola-x86_64-unknown-linux-gnu.tar.gz",
    "linux_arm64": "zola-aarch64-unknown-linux-gnu.tar.gz",
    "darwin_amd64": "zola-x86_64-apple-darwin.tar.gz",
    "darwin_arm64": "zola-aarch64-apple-darwin.tar.gz",
    "windows_amd64": "zola-x86_64-pc-windows-msvc.zip",
    "windows_arm64": "NO_MATCH"
  }
}
